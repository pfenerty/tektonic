{
  "name": "@pfenerty/tektonic",
  "version": "1.1.0",
  "description": "CDK8s constructs for composing Tekton pipelines as code",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/pfenerty/tektonic.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/**/*.js.map",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:scripts": "npm run build && node scripts/lint-scripts.cjs",
    "docs:api": "typedoc",
    "synth": "npx cdk8s synth",
    "import": "npx cdk8s import",
    "prepare": "npm run build"
  },
  "peerDependencies": {},
  "dependencies": {
    "cdk8s": "^2.68.0",
    "constructs": "^10.3.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "cdk8s-cli": "^2.198.0",
    "ts-node": "^10.9.0",
    "typescript": "~7.0.0",
    "vitest": "^4.0.0",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.0.0"
  }
}
